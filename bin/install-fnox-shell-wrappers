#!/usr/bin/env bash
# Generate the fnox shell-wrapper files (idempotent).
#
# Wraps package managers (npm/yarn/pnpm/bun/...) with `fnox exec` so the registry
# token is injected per-invocation into the tool's env only — never the parent shell.
# Delivered as shell FUNCTIONS, NOT a PATH shim, because:
#   - Interactive zsh/bash/fish AND Claude Code's Bash tool all route package managers
#     through fnox. Claude Code sources ~/.zshrc at session start and replays the captured
#     functions to every Bash command, so non-interactive `bash -c npm ...` is covered too
#     (docs.claude.com/en/tools-reference#bash-tool-behavior).
#   - mise's own subprocesses (e.g. the `npm:npm` backend that bootstraps npm by running
#     npm) do NOT inherit shell functions, so they resolve the real npm via PATH — no
#     recursion, and per-project version pinning installs cleanly. A PATH shim sat ahead of
#     that bootstrap npm and recursed; functions avoid it entirely.
#   - Resolution/errors are delegated to mise. A pinned-but-uninstalled tool is NOT
#     auto-installed here — run `mise install` (for an npm pin: `fnox exec -- mise install`,
#     since the FLATT default registry needs the token even to resolve npm itself).
# Bypass a wrapper with `command <tool>` (or `\<tool>`).
#
# This script owns two GENERATED files (the TOOLS list below is the single source of
# truth, so adding a tool only edits this script):
#   - bin/fnox-wrappers.sh                   POSIX functions; `~/.zshrc`/`~/.bashrc` source it
#   - .config/fish/conf.d/fnox-wrappers.fish fish auto-sources conf.d/*.fish
# The one-time `source` line in ~/.zshrc / ~/.bashrc is added by hand (see README / docs);
# this script never edits those rc files.
#
# Tradeoff: a raw non-shell subprocess that runs a package manager directly (a Makefile's
# `sh -c npm`, a Node child_process, a git hook) does not inherit the function and won't
# get the token. npm's own lifecycle/postinstall scripts DO inherit it. See docs.

set -euo pipefail

DOT_DIRECTORY="${DOT_DIRECTORY:-${HOME}/dotfiles}"

# Single source of truth: package managers to wrap with `fnox exec`.
TOOLS=(npm npx yarn bun bunx pnpm pnpx)

HEADER="\
# fnox shell wrappers — generated by bin/install-fnox-shell-wrappers (edit the TOOLS list there).
# Route package managers through \`fnox exec\` (registry token injected per-invocation).
# Bypass with \`command <tool>\`. Version resolution / install is delegated to mise."

# Render a wrapper file body. $1 = printf template for one tool (takes the name twice).
emit() {
    printf '%s\n' "$HEADER"
    local t
    for t in "${TOOLS[@]}"; do
        # shellcheck disable=SC2059  # $1 is a trusted in-script format, not user input.
        printf "$1" "$t" "$t"
    done
}

# Write a generated file, skipping the write (and mtime churn) when unchanged. Idempotent.
write_file() {
    local dest="$1" content="$2"
    mkdir -p "$(dirname "$dest")"
    if [ -e "$dest" ] && [ "$content" = "$(<"$dest")" ]; then
        printf 'unchanged: %s\n' "$dest"
    else
        printf '%s\n' "$content" >"$dest"
        printf 'updated:   %s\n' "$dest"
    fi
}

# The single-quoted templates intentionally contain literal `"$@"` / `$argv` — they are
# printf formats written verbatim into the generated wrapper files, not expanded here.
# shellcheck disable=SC2016
write_file "${DOT_DIRECTORY}/bin/fnox-wrappers.sh" \
    "$(emit '%s() { fnox exec -- %s "$@"; }\n')"
# shellcheck disable=SC2016
write_file "${DOT_DIRECTORY}/.config/fish/conf.d/fnox-wrappers.fish" \
    "$(emit 'function %s; fnox exec -- %s $argv; end\n')"
