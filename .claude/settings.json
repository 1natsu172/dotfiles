  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "api.github.com"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.gnupg",
        "~/ghq"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.bashrc",
        "~/.zshrc",
        "~/.config/fish"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "gh pr create",
      "gh pr edit",
      "gh pr merge",
      "gh pr close",
      "gh pr reopen",
      "gh pr ready",
      "gh pr comment",
      "gh pr review",
      "gh issue create",
      "gh issue edit",
      "gh issue close",
      "gh issue reopen",
      "gh issue comment",
      "gh release create",
      "gh release edit",
      "gh release delete"
    ]
  },
  "effortLevel": "xhigh",
  "teammateMode": "auto",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "extraKnownMarketplaces": {
    "voltagent-subagents": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      }
    }
  }
}
