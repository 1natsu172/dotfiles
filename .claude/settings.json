  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "api.github.com"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.gnupg",
        "~/ghq"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.bashrc",
        "~/.zshrc",
        "~/.config/fish",
        "~/.npmrc",
        "~/.netrc",
        "~/.gnupg/private-keys-v1.d",
        "~/.kube",
        "~/.docker",
        "~/.config/op",
        "~/.gitconfig"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.npmrc",
        "~/.netrc",
        "~/.gnupg/private-keys-v1.d",
        "~/.kube",
        "~/.docker",
        "~/.config/op",
        "~/.config/1Password",
        "~/.gitconfig"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "gh pr create",
      "gh pr edit",
      "gh pr merge",
      "gh pr close",
      "gh pr reopen",
      "gh pr ready",
      "gh pr comment",
      "gh pr review",
      "gh issue create",
      "gh issue edit",
      "gh issue close",
      "gh issue reopen",
      "gh issue comment",
      "gh release create",
      "gh release edit",
      "gh release delete"
    ]
  },
  "effortLevel": "xhigh",
  "teammateMode": "auto",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
